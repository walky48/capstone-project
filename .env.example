# EmailJS credentials (https://www.emailjs.com → Account / Email Services / Email Templates)
# Copy this file to ".env" and fill in your own values, then restart `npm run dev`.
#
# The EmailJS template must include these variables:
#   {{to_email}}  {{to_name}}  {{subject}}  {{message}}  {{code}}
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
